generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ORGANIZER
  ADMIN
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  COMPLETED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum ValidationStatus {
  VALID
  USED
  INVALID
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  role         UserRole @default(USER)
  passwordHash String   @map("password_hash")
  avatarUrl    String?  @map("avatar_url")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  events        Event[]
  orders        Order[]
  rsvps         RSVP[]
  attendees     Attendee[]

  @@map("users")
}

model Event {
  id           String      @id @default(cuid())
  organizerId  String      @map("organizer_id")
  title        String
  description  String
  venue        String
  dateTime     DateTime    @map("date_time")
  category     String
  bannerUrl    String?     @map("banner_url")
  status       EventStatus @default(DRAFT)
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  organizer     User          @relation(fields: [organizerId], references: [id])
  ticketTypes   TicketType[]
  orders        Order[]
  rsvps         RSVP[]
  attendees     Attendee[]

  @@map("events")
}

model TicketType {
  id        String   @id @default(cuid())
  eventId   String   @map("event_id")
  name      String
  price     Decimal  @db.Decimal(10, 2)
  quantity  Int
  createdAt DateTime @default(now()) @map("created_at")

  event          Event            @relation(fields: [eventId], references: [id])
  ticketInstances TicketInstance[]

  @@map("ticket_types")
}

model Order {
  id            String        @id @default(cuid())
  userId        String        @map("user_id")
  eventId       String        @map("event_id")
  amount        Decimal       @db.Decimal(10, 2)
  paymentStatus PaymentStatus @default(PENDING) @map("payment_status")
  createdAt     DateTime      @default(now()) @map("created_at")

  user           User            @relation(fields: [userId], references: [id])
  event          Event           @relation(fields: [eventId], references: [id])
  payments       Payment[]
  ticketInstances TicketInstance[]

  @@map("orders")
}

model Payment {
  id               String        @id @default(cuid())
  orderId          String        @map("order_id")
  flutterwaveTxnRef String       @unique @map("flutterwave_txn_ref")
  amount           Decimal       @db.Decimal(10, 2)
  currency         String        @default("NGN")
  status           PaymentStatus @default(PENDING)
  createdAt        DateTime      @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id])

  @@map("payments")
}

model TicketInstance {
  id               String           @id @default(cuid())
  orderId          String           @map("order_id")
  ticketTypeId     String           @map("ticket_type_id")
  qrUuid           String           @unique @map("qr_uuid")
  qrCode           String           @map("qr_code")
  validationStatus ValidationStatus @default(VALID) @map("validation_status")
  validatedAt      DateTime?        @map("validated_at")
  createdAt        DateTime         @default(now()) @map("created_at")

  order      Order     @relation(fields: [orderId], references: [id])
  ticketType TicketType @relation(fields: [ticketTypeId], references: [id])
  attendee   Attendee?

  @@map("ticket_instances")
}

model RSVP {
  id      String   @id @default(cuid())
  eventId String   @map("event_id")
  userId  String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@unique([eventId, userId])
  @@map("rsvps")
}

model Attendee {
  id              String   @id @default(cuid())
  eventId         String   @map("event_id")
  userId          String   @map("user_id")
  ticketInstanceId String  @unique @map("ticket_instance_id")
  checkedInAt     DateTime? @map("checked_in_at")
  createdAt       DateTime @default(now()) @map("created_at")

  event          Event          @relation(fields: [eventId], references: [id])
  user           User           @relation(fields: [userId], references: [id])
  ticketInstance TicketInstance @relation(fields: [ticketInstanceId], references: [id])

  @@map("attendees")
}
